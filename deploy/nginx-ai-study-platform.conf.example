# =============================================================================
# Nginx configuration template for ai_study_platform
#
# Copy to /etc/nginx/sites-available/ and symlink to sites-enabled/.
# After making changes:
#   sudo nginx -t
#   sudo systemctl reload nginx
# =============================================================================

server {
    listen 80;
    server_name _;                    # change to your domain if needed

    # ── Frontend static files ──
    root /var/www/ai_study_platform;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;
    }

    # ── Backend API (REST) ──
    # Proxies /api/* → FastAPI backend, stripping /api prefix
    location /api/ {
        proxy_pass http://127.0.0.1:8000/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_read_timeout 300s;
        proxy_send_timeout 300s;
    }

    # ── CodeStudio Interactive Terminal WebSocket (primary path) ──
    # The frontend connects to ws://host/code/interactive-run
    location /code/interactive-run {
        proxy_pass http://127.0.0.1:8000/code/interactive-run;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }

    # ── CodeStudio Interactive Terminal WebSocket (alternate path) ──
    # Fallback when the frontend tries ws://host/api/code/interactive-run
    location /api/code/interactive-run {
        proxy_pass http://127.0.0.1:8000/api/code/interactive-run;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
    }
}
